<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    tools:context=".activities.ResetPasswordActivity">

    <!-- Premium Gradient Header Background -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_gradient_blue"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/pageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Email Verification"
        android:textColor="@android:color/white"
        android:textSize="@dimen/text_display"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/pageSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:gravity="center"
        android:text="Securing your connection to the transport network."
        android:textColor="#E3F2FD"
        android:textSize="@dimen/text_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pageTitle" />

    <!-- Interactive Status Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/screen_margin_large"
        android:layout_marginTop="180dp"
        app:cardCornerRadius="@dimen/radius_xlarge"
        app:cardElevation="@dimen/elevation_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/padding_xxlarge">

            <!-- Dynamic State View Container -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <!-- Loading State (Progress Bar) -->
                <ProgressBar
                    android:id="@+id/pbLoader"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#3949AB" />

                <!-- Success State Icon -->
                <ImageView
                    android:id="@+id/ivSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_light_teal"
                    android:padding="16dp"
                    android:src="@drawable/ic_verified_check"
                    android:visibility="gone" />

                <!-- Error State Icon -->
                <ImageView
                    android:id="@+id/ivError"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_light_red"
                    android:padding="16dp"
                    android:src="@drawable/ic_verification_error"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- State Title -->
            <TextView
                android:id="@+id/tvVerificationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verifying Your Email"
                android:textColor="#1A237E"
                android:textSize="@dimen/text_header"
                android:textStyle="bold" />

            <!-- State Details -->
            <TextView
                android:id="@+id/tvVerificationDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="We are currently verifying your credentials. Please hold on a moment."
                android:textColor="#616161"
                android:textSize="@dimen/text_medium" />

            <!-- Action Button -->
            <Button
                android:id="@+id/btnBackToLogin"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_btn_gradient"
                android:text="Back to Login"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_large"
                android:visibility="gone"
                app:cornerRadius="@dimen/radius_small" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
