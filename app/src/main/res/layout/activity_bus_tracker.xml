<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    tools:context=".activities.BusTrackerActivity">

    <!-- ===== TOP HEADER ===== -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        android:background="#0A0E1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnTrackerBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvTrackerBusId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUS_001"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvTrackerRouteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Addis Ababa City Bus"
                android:textColor="#7B8FBF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Live Pulse Dot -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/livePulseDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_live_dot"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="#00E676"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== ROUTE TIMELINE (Origin → Destination) ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRouteTimeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#141929"
        app:layout_constraintTop_toBottomOf="@+id/headerBar"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Origin / Destination Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FROM"
                        android:textColor="#7B8FBF"
                        android:textSize="10sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tvFromStop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bole"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentStopTracker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Stop"
                        android:textColor="#00E676"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Progress Arrow Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Bus Icon animated along progress -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/progressLeft"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_weight="1"
                            android:background="#2979FF" />

                        <TextView
                            android:id="@+id/tvBusIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚌"
                            android:textSize="20sp"
                            android:layout_marginHorizontal="4dp" />

                        <View
                            android:id="@+id/progressRight"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_weight="1"
                            android:background="#1E2A45" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45%"
                        android:textColor="#2979FF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TO"
                        android:textColor="#7B8FBF"
                        android:textSize="10sp"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tvToStop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Megenagna"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNextStopTracker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next Stop"
                        android:textColor="#FF9100"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== MAIN COUNTERS (Distance + Time) ===== -->
    <LinearLayout
        android:id="@+id/counterRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/cardRouteTimeline"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Distance Counter Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#141929">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 DISTANCE"
                    android:textColor="#7B8FBF"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvLiveDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.47"
                    android:textColor="#2979FF"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvDistanceUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km to station"
                    android:textColor="#7B8FBF"
                    android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ETA Counter Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#141929">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ ETA"
                    android:textColor="#7B8FBF"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvLiveEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="07:32"
                    android:textColor="#00E676"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvEtaLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="min:sec remaining"
                    android:textColor="#7B8FBF"
                    android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ===== SPEED + PASSENGERS ROW ===== -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/counterRow"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Speed -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#141929">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPEED"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tvLiveSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20"
                    android:textColor="#FF9100"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Passengers -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#141929">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ONBOARD"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tvLivePassengers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18/30"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="passengers"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#141929">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tvLiveStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="#00E676"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLiveStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moving"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ===== TOTAL TRIP DISTANCE CARD ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTotalTrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#141929"
        app:layout_constraintTop_toBottomOf="@+id/statsRow"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL DISTANCE TO DESTINATION"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvTotalDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.2 km"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  remaining"
                        android:textColor="#7B8FBF"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end|center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL ETA"
                    android:textColor="#7B8FBF"
                    android:textSize="9sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvTotalEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~15 min"
                    android:textColor="#FF9100"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== BUS INFO CARD ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBusInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#141929"
        app:layout_constraintTop_toBottomOf="@+id/cardTotalTrip"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUS INFORMATION"
                android:textColor="#7B8FBF"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <!-- Row 1: Type + Driver -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bus Type"
                        android:textColor="#7B8FBF"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvInfoBusType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anbessa City Bus"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver"
                        android:textColor="#7B8FBF"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvInfoDriver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unknown"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2A45"
                android:layout_marginVertical="12dp" />

            <!-- Row 2: Terminal + Route -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Terminal"
                        android:textColor="#7B8FBF"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvInfoTerminal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Piazza"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Route ID"
                        android:textColor="#7B8FBF"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvInfoRoute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Route 93"
                        android:textColor="#2979FF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== LAST UPDATED STAMP ===== -->
    <TextView
        android:id="@+id/tvLastUpdated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last updated: just now"
        android:textColor="#3A4560"
        android:textSize="11sp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@+id/cardBusInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
