<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvCompSubject"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Subject"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp"/>

            <ImageView
                android:id="@+id/btnDeleteComplaint"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#D32F2F"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvNewReplyBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:textColor="#FFFFFF"
                android:background="#FF1744"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvCompStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_status_pending"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCompMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Message content here..."
            android:textColor="#666666"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvViewMoreMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View All"
            android:textColor="#1976D2"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:paddingVertical="4dp"
            android:paddingEnd="16dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/layoutAdminReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Reply:"
                android:textStyle="bold"
                android:textColor="#3F51B5"
                android:textSize="11sp"/>
            <TextView
                android:id="@+id/tvAdminReply"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Response here..."
                android:textColor="#333333"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
            <TextView
                android:id="@+id/tvViewMoreReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View All"
                android:textColor="#1976D2"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:paddingVertical="4dp"
                android:paddingEnd="16dp"
                android:visibility="gone"/>
        </LinearLayout>
        
        <TextView
            android:id="@+id/tvCompTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="10:30 AM"
            android:textColor="#999999"
            android:textSize="10sp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
