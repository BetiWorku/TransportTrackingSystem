<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_dialog_map"
            app:tint="#3F51B5" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/busName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bus #101"
                android:textColor="#333333"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/busDestination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To: Stadium"
                android:textColor="#5C6BC0"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/busDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.5 km away"
                android:textColor="#9E9E9E"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                
                <TextView
                    android:id="@+id/tvBusType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anbessa"
                    android:background="#E3F2FD"
                    android:textColor="#1976D2"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvPassengers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18/30"
                    android:textColor="#43A047"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCurrentStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Current: Bole"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/tvNextStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next: Megenagna"
                android:textColor="#757575"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/busEta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_eta_pill"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="8 mins"
            android:textColor="#3F51B5"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
